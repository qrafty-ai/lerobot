{
  "dataset": {
    "repo_id": "qrafty-ai/use_spoon_joint_0311"
  },
  "policy": {
    "type": "xvla",
    "pretrained_path": "lerobot/xvla-base",
    "device": "cuda",
    "dtype": "bfloat16",
    "push_to_hub": false,
    "action_mode": "chunk_delta_joint",
    "chunk_size": 60,
    "n_action_steps": 30,
    "domain_feature_key": 13,
    "num_denoising_steps": 10,
    "use_proprio": true,
    "max_state_dim": 52,
    "max_action_dim": 20,
    "allow_reinit_action_encoder_for_larger_max_state_dim": true,
    "gripper_indices": [16, 17],
    "num_image_views": 3,
    "resize_imgs_with_padding": [224, 224],
    "freeze_vision_encoder": false,
    "freeze_language_encoder": false,
    "train_policy_transformer": true,
    "train_soft_prompts": true
  },
  "output_dir": "outputs/train/xvla_chunk_delta_joint",
  "job_name": "xvla_chunk_delta_joint",
  "seed": 1000,
  "num_workers": 10,
  "batch_size": 8,
  "steps": 20000,
  "log_freq": 50,
  "save_freq": 10000,
  "eval_freq": 5000,
  "wandb": {
    "enable": true
  }
}
